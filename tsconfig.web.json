{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist/web",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/renderer/components/*"],
      "@constants": ["src/shared/constants"],
      "@types": ["src/shared/types"],
      "@assets/*": ["assets/*"]
    }
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"]
}
